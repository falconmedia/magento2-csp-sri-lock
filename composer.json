{
    "name": "falconmedia/magento2-csp-sri-lock",
    "description": "Prevents corrupted sri-hashes.json in Magento 2 by adding atomic writes and file locking.",
    "type": "magento2-module",
    "license": "MIT",
    "require": {
        "php": "^8.1 || ^8.2, ^8.3",
        "magento/framework": "^103.0",
        "magento/module-csp": "^100.4"
    },
    "autoload": {
        "files": [
            "src/registration.php"
        ],
        "psr-4": {
            "FalconMedia\\CspSriLock\\": "src/"
        }
    }
}
